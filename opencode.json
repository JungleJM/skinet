{
  "mcp": {
    "tenet": {
      "type": "local",
      "command": [
        "tenet",
        "serve"
      ]
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    }
  },
  "permission": {
    "mcp": {
      "playwright": "allow"
    }
  }
}
